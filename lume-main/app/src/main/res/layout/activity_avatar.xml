<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_degrade">

    <LinearLayout
        android:id="@+id/card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="#CCFFFFFF"
        android:elevation="8dp"
        android:layout_margin="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/txt_mensagem2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp"
            android:fontFamily=""
            android:text="Escolha seu avatar"
            android:textColor="#4A90E2"
            android:textSize="22sp" />

        <GridLayout
            android:id="@+id/grid_avatares"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="3"
            android:layout_gravity="center">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/avatar1"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_margin="10dp"
                android:src="@drawable/avatar1"
                android:scaleType="centerCrop"
                app:strokeColor="#A8E6A3"
                app:strokeWidth="0dp"
                app:shapeAppearanceOverlay="@style/CircleImage" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/avatar2"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_margin="10dp"
                android:src="@drawable/avatar2"
                android:scaleType="centerCrop"
                app:strokeColor="#A8E6A3"
                app:strokeWidth="0dp"
                app:shapeAppearanceOverlay="@style/CircleImage" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/avatar3"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_margin="10dp"
                android:src="@drawable/avatar3"
                android:scaleType="centerCrop"
                app:strokeColor="#A8E6A3"
                app:strokeWidth="0dp"
                app:shapeAppearanceOverlay="@style/CircleImage" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/avatar4"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_margin="10dp"
                android:src="@drawable/avatar4"
                android:scaleType="centerCrop"
                app:strokeColor="#A8E6A3"
                app:strokeWidth="0dp"
                app:shapeAppearanceOverlay="@style/CircleImage" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/avatar5"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_margin="10dp"
                android:src="@drawable/avatar5"
                android:scaleType="centerCrop"
                app:strokeColor="#A8E6A3"
                app:strokeWidth="0dp"
                app:shapeAppearanceOverlay="@style/CircleImage" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/avatar6"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_margin="10dp"
                android:src="@drawable/avatar6"
                android:scaleType="centerCrop"
                app:strokeColor="#A8E6A3"
                app:strokeWidth="0dp"
                app:shapeAppearanceOverlay="@style/CircleImage" />

        </GridLayout>

        <Button
            android:id="@+id/btn_confirmar_avatar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="32dp"
            android:backgroundTint="#A8E6A3"
            android:text="Esse sou eu"
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>